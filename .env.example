# MARS — environment variables (all optional)
# Copy to .env to override defaults. opencode (or your MCP client) loads it.

# Directory holding the world's text files (rooms, artifacts, inventories).
# Defaults to ./world
# MARS_WORLD_DIR=world

# MARS has NO model/provider configuration of its own — your agent (opencode, or any
# MCP client) owns the models. Configure providers there, not here.
